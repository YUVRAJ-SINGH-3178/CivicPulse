PORT=5000
NODE_ENV=development

# MongoDB Atlas example:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/civicpulse

# Optional legacy PostgreSQL config. The current app uses MongoDB for issue reports.
DATABASE_URL=

# Optional media/profile integrations
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
